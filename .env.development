# Backend API base URL used by frontend requests.
# Development recommended value: /api (use Vite proxy to avoid CORS)
VITE_API_BASE_URL=/api

# Vite dev proxy target backend URL.
VITE_API_PROXY_TARGET=http://localhost:8080

# WeChat Mini Program AppID
VITE_WECHAT_APP_ID=your_wechat_app_id

# Enable development tools for WeChat Mini Program
VITE_ENABLE_DEV_WECHAT_TOOLS=true 